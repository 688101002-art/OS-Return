#include <iostream>
#include <iomanip>
#include <cstdlib> // แก้ไขจาก cstdlip
#include <ctime>

using namespace std;

const int NUM_PAGES = 64;
const int NUM_FRAMES = 32;
const int PAGE_SIZE = 1024;

class PageTable {
private:
    int pageTable[NUM_PAGES];
    bool valid[NUM_PAGES];

public:
    PageTable() {
        srand(time(0));
        for (int i = 0; i < NUM_PAGES; i++) {
            // สุ่มหมายเลข Frame (0-31)
            pageTable[i] = rand() % NUM_FRAMES;
            // สุ่มให้ 70% ของ Page เป็น Valid
            valid[i] = (rand() % 100 < 70);
        }
    }

    int translateAddress(int logicalAddress) {
        // 1. แยก Page Number และ Offset
        int pageNumber = logicalAddress / PAGE_SIZE;
        int offset = logicalAddress % PAGE_SIZE;

        // ตรวจสอบขอบเขต
        if (pageNumber >= NUM_PAGES) {
            cout << "Error: Logical Address out of range!" << endl;
            return -1;
        }

        // 2. ตรวจสอบว่าหน้าเหล่านั้นอยู่ใน Memory หรือไม่ (Valid bit)
        if (!valid[pageNumber]) {
            cout << "Page Fault: Page " << pageNumber << " is invalid!" << endl;
            return -1;
        }

        // 3. คำนวณ Physical Address
        int frameNumber = pageTable[pageNumber];
        int physicalAddress = (frameNumber * PAGE_SIZE) + offset;

        return physicalAddress;
    }

    void displayPageTable() {
        cout << "\n--- Page Table (Sample) ---\n";
        cout << setw(10) << "Page No" << setw(12) << "Frame No" << setw(10) << "Status" << endl;
        for (int i = 0; i < 10; i++) { // แสดงแค่ 10 หน้าแรกเป็นตัวอย่าง
            cout << setw(10) << i 
                 << setw(12) << pageTable[i] 
                 << setw(10) << (valid[i] ? "Valid" : "Invalid") << endl;
        }
        cout << "...\n";
    }
};

int main() {
    PageTable pt;
    
    pt.displayPageTable();

    // ทดสอบ Logical Address
    int testAddresses[] = {2048, 512, 10245, 65000}; 

    cout << "\n--- Address Translation Results ---\n";
    for (int la : testAddresses) {
        int pa = pt.translateAddress(la);
        cout << "Logical: " << setw(7) << la << " => ";
        if (pa != -1) {
            cout << "Physical: " << pa << endl;
        } else {
            cout << "Translation Failed" << endl;
        }
    }

    return 0;
}
